# ============================================================================
# SINGLE env file for the whole project. Copy to `.env` and fill in values:
#   cp .env.example .env
# `.env` is gitignored. Read by the backend (spring-dotenv), the Vite build,
# and Docker Compose. Real environment variables override these in production.
# ============================================================================

# ---- Server ----
SERVER_PORT=8081

# ---- Slack tokens (at least one required) ----
# xoxp-... user tokens or xoxb-... bot tokens.
SLACK_ADMIN_TOKEN=
SLACK_USER_TOKEN=
# Optional: comma-separated additional user tokens for multi-token fetch.
SLACK_USER_TOKENS=

# ---- Optional channel-ID filters (comma-separated) ----
SLACK_DM_CHANNEL_IDS=
SLACK_MPIM_CHANNEL_IDS=

# ---- Slack API tuning ----
SLACK_API_BASE_URL=https://slack.com/api
SLACK_CONNECT_TIMEOUT_MS=30000
SLACK_RATE_LIMIT_MAX_RETRIES=100
SLACK_RATE_LIMIT_INITIAL_BACKOFF_MS=1000
SLACK_ENRICHMENT_DELAY_MS=800

# ---- Export behaviour ----
EXPORT_SAVE_DIR=exports
EXPORT_SLACK_CHANNEL_DELAY_MS=1200
EXPORT_CLEANUP_MAX_AGE_HOURS=24
EXPORT_CLEANUP_CRON=0 0 * * * *

# ---- Logging ----
LOG_LEVEL_APP=DEBUG

# ---- Frontend build (Vite) ----
# Empty => browser uses relative /api (proxied by nginx, same-origin). Set a full URL only for a different API origin.
VITE_API_BASE_URL=
VITE_DEV_PORT=3000
VITE_API_PROXY_TARGET=http://localhost:8081

# ---- Deployment / TLS (Docker Compose only) ----
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=you@example.com
