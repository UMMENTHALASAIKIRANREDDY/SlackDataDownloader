# Docker Compose deployment config (ROOT). Copy to `.env` on the server: cp .env.example .env
# This file is for TLS + nginx only. Backend app secrets live in backend/.env.

# The domain that points (DNS A record) at this server's public IP.
DOMAIN=your-domain.com

# Email for Let's Encrypt expiry notices.
LETSENCRYPT_EMAIL=you@example.com
