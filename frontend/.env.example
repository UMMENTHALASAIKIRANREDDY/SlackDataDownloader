# Copy this file to `.env` and adjust. `.env` is gitignored. Only VITE_* vars are exposed to the client.

# Dev server port
VITE_DEV_PORT=3000

# Dev-only: where the Vite dev server proxies /api to (avoids CORS in dev)
VITE_API_PROXY_TARGET=http://localhost:8081

# Backend base URL the browser calls.
# Leave EMPTY to use relative /api (dev proxy, or same-origin reverse proxy in prod).
# Set to a full URL (e.g. https://api.example.com) only if backend is on a different origin.
VITE_API_BASE_URL=
